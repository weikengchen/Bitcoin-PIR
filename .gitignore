# Rust build artifacts
target/

# Workspace-root /Cargo.lock IS tracked for reproducibility (required by
# PHASE3_SLICE3_REPRO_PLAN.md sub-tasks 2 + 4). Stray sub-crate lockfiles
# (workspace members + excluded sub-projects like
# electrum_plugin/harmonypir-python) shouldn't be tracked — Cargo writes
# a single root lockfile for the workspace, and excluded sub-projects
# have their own reproducibility story.
Cargo.lock
!/Cargo.lock

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Project specific
block_tx_counts.bin
data/*.bin
data/*.dat
*.log

# Node.js
node_modules/
dist/
*.tsbuildinfo

# Python
__pycache__/
*.pyc
*.pyo
*.dylib

# Electrum plugin build artifacts
pir_privacy-*.zip
electrum_plugin/pir_privacy/_vendor/

# Java / Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
*.class

# Planning docs
PLAN_*.md

# Claude Code
.claude/

# Deployment artifacts (local configs, secrets, notes, SSH known_hosts)
deploy/

# vendor/ holds `cargo vendor` output. Each crate ships a
# `.cargo-checksum.json` listing every file with its hash; dropping any
# referenced file (Cargo.lock, build/*.rs, src/target/*.rs, .DS_Store,
# .claude/*) breaks fresh-clone offline builds with
# "failed to calculate checksum of: vendor/<crate>/<file>".
# Keep vendor/ verbatim — un-ignore everything inside it so the broader
# rules above (target/, build/, .DS_Store, .claude/, Cargo.lock) don't
# bite vendored crates.
!vendor/**
# dev-issuer demo key files (never commit)
arc_key.bin
cashu_key.bin
